# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files — keep the example, ignore real secrets
.env*
!.env.example

# next dev --experimental-https certificates
/certificates

# vercel
.vercel

# claude code — local machine settings (permissions etc.), not shared
.claude/settings.local.json
.claude/scheduled_tasks.lock

# playwright-mcp debug artifacts (console/page captures from the dev session)
/.playwright-mcp

# typescript
*.tsbuildinfo
next-env.d.ts
